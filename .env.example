# CyberBrief — Local Environment Variables
# Copy this file to .env and fill in your real values.
# .env is gitignored and never committed.

# Groq API key — free tier at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Webex Bot — create at https://developer.webex.com
WEBEX_BOT_TOKEN=your_webex_bot_token_here
WEBEX_ROOM_ID=your_webex_room_id_here

# Telegram Bot — created via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_channel_chat_id_here

BITLY_API_TOKEN=your_bitly_api_token_here
